{
	"name": "@cloudillo/scanillo-app",
	"version": "0.8.10",
	"description": "Scanillo document scanner app",
	"type": "module",
	"main": "src/index.js",
	"scripts": {
		"ts": "tsc --noEmit",
		"ts-watch": "tsc --noEmit --watch",
		"build": "pnpm run ts && cross-env NODE_ENV=production node esbuild.config.js",
		"watch": "node esbuild.config.js --watch",
		"clean": "rimraf .cache dist/assets-*"
	},
	"author": "Szilárd Hajba <szilu@cloudillo.org",
	"license": "LGPL-3.0-or-later",
	"dependencies": {
		"jscanify": "^1.4.0",
		"pdf-lib": "^1.17.1"
	},
	"devDependencies": {
		"@cloudillo/core": "workspace:^",
		"@cloudillo/react": "workspace:^",
		"@cloudillo/rtdb": "workspace:^",
		"@symbion/opalui": "^0.14.5",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"cross-env": "^10.1.0",
		"esbuild": "^0.27.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-icons": "^5.6.0",
		"react-router-dom": "^7.13.1",
		"rimraf": "^6.1.3",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3"
	}
}
