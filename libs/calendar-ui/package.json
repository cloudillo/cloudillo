{
	"name": "@cloudillo/calendar-ui",
	"version": "0.8.16",
	"description": "React calendar component — day, week, and month views with drag, resize, and touch support",
	"keywords": [
		"cloudillo",
		"react",
		"calendar",
		"scheduler",
		"day-view",
		"week-view",
		"month-view",
		"drag-and-drop"
	],
	"homepage": "https://cloudillo.org",
	"repository": {
		"type": "git",
		"url": "https://github.com/cloudillo/cloudillo.git",
		"directory": "libs/calendar-ui"
	},
	"bugs": {
		"url": "https://github.com/cloudillo/cloudillo/issues"
	},
	"type": "module",
	"main": "lib/index.js",
	"exports": {
		".": "./lib/index.js",
		"./calendar-ui.css": "./lib/calendar-ui.css"
	},
	"files": [
		"lib",
		"README.md"
	],
	"scripts": {
		"ts": "tsgo --noEmit",
		"build": "tsgo && cp src/calendar-ui.css lib/",
		"build-ts": "tsc && cp src/calendar-ui.css lib/",
		"watch": "tsgo -w",
		"clean": "rimraf .cache lib*"
	},
	"author": "Szilárd Hajba <szilu@cloudillo.org>",
	"license": "LGPL-3.0-or-later",
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@types/react": "^19.2.17",
		"rimraf": "^6.1.3",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"react": "^19.1.0"
	},
	"dependencies": {
		"dayjs": "^1.11.21"
	}
}
