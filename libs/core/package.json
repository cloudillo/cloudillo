{
	"name": "@cloudillo/core",
	"version": "0.8.13",
	"description": "Client SDK, API client, and app message bus for Cloudillo — building blocks for apps on the decentralized collaboration platform",
	"keywords": [
		"cloudillo",
		"sdk",
		"api-client",
		"message-bus",
		"jotai",
		"decentralized",
		"collaboration",
		"self-hosted"
	],
	"homepage": "https://cloudillo.org",
	"repository": {
		"type": "git",
		"url": "https://github.com/cloudillo/cloudillo.git",
		"directory": "libs/core"
	},
	"bugs": {
		"url": "https://github.com/cloudillo/cloudillo/issues"
	},
	"type": "module",
	"main": "lib/index.js",
	"exports": {
		".": {
			"import": "./lib/index.js",
			"types": "./lib/index.d.ts"
		},
		"./types": {
			"import": "./lib/types.ts",
			"types": "./lib/types.d.ts"
		}
	},
	"files": [
		"lib",
		"README.md"
	],
	"scripts": {
		"ts": "tsc --noEmit",
		"build": "tsc",
		"watch": "tsc -w",
		"test": "NODE_OPTIONS=\"--experimental-vm-modules\" jest",
		"test:watch": "NODE_OPTIONS=\"--experimental-vm-modules\" jest --watch",
		"test:coverage": "NODE_OPTIONS=\"--experimental-vm-modules\" jest --coverage",
		"clean": "rimraf .cache lib*"
	},
	"author": "Szilárd Hajba <szilu@cloudillo.org>",
	"license": "LGPL-3.0-or-later",
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@cloudillo/types": "workspace:^"
	},
	"devDependencies": {
		"@symbion/runtype": "^1.2.1",
		"@types/jest": "^30.0.0",
		"colord": "^2.9.3",
		"jest": "^30.3.0",
		"jest-environment-jsdom": "^30.3.0",
		"jotai": "^2.20.0",
		"rimraf": "^6.1.3",
		"ts-jest": "^29.4.9",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3"
	}
}
