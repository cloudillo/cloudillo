		"access": "public"
	},
	"dependencies": {
		"@cloudillo/core": "workspace:^"
	},
	"devDependencies": {
		"lib0": "^0.2.117",
		"rimraf": "^6.1.3",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"y-indexeddb": "^9.0.12",
		"y-protocols": "^1.0.7",
		"y-websocket": "3.0.0",
		"yjs": "^13.6.30"
	}
}
