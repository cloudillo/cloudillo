{
	"name": "@cloudillo/crdt",
	"version": "0.8.13",
	"description": "Yjs CRDT collaborative editing client for Cloudillo — IndexedDB persistence, awareness, and WebSocket sync",
	"keywords": [
		"cloudillo",
		"yjs",
		"crdt",
		"real-time",
		"collaborative-editing",
		"websocket",
		"y-indexeddb",
		"decentralized"
	],
	"homepage": "https://cloudillo.org",
	"repository": {
		"type": "git",
		"url": "https://github.com/cloudillo/cloudillo.git",
		"directory": "libs/crdt"
	},
	"bugs": {
		"url": "https://github.com/cloudillo/cloudillo/issues"
	},
	"type": "module",
	"main": "lib/index.js",
	"exports": {
		".": {
			"import": "./lib/index.js",
			"types": "./lib/index.d.ts"
		}
	},
	"files": [
		"lib",
		"README.md"
	],
	"scripts": {
		"ts": "tsc --noEmit",
		"build": "tsc",
		"watch": "tsc -w",
		"clean": "rimraf .cache lib*"
	},
