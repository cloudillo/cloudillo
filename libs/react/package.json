{
	"name": "@cloudillo/react",
	"version": "0.8.13",
	"description": "React hooks and component library for Cloudillo apps — auth, real-time data, i18n, and OpalUI integration",
	"keywords": [
		"cloudillo",
		"react",
		"hooks",
		"components",
		"ui",
		"i18n",
		"jotai",
		"decentralized",
		"collaboration"
	],
	"homepage": "https://cloudillo.org",
	"repository": {
		"type": "git",
		"url": "https://github.com/cloudillo/cloudillo.git",
		"directory": "libs/react"
	},
	"bugs": {
		"url": "https://github.com/cloudillo/cloudillo/issues"
	},
	"type": "module",
	"main": "lib/index.js",
	"exports": {
		".": "./lib/index.js",
		"./components.css": "./lib/components.css"
	},
	"files": [
		"lib",
		"README.md"
	],
	"jest": {
		"preset": "ts-jest",
		"moduleNameMapper": {
			"^~/(.*)$": "<rootDir>/$1"
		}
	},
	"scripts": {
		"ts": "tsc --noEmit",
		"build": "tsc && cp src/components.css lib/",
		"watch": "tsc -w",
		"clean": "rimraf .cache lib*"
	},
	"author": "Szilárd Hajba <szilu@cloudillo.org>",
	"license": "LGPL-3.0-or-later",
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@cloudillo/core": "workspace:^",
		"@cloudillo/crdt": "workspace:^",
		"@cloudillo/fonts": "workspace:^",
		"@cloudillo/rtdb": "workspace:^",
		"@cloudillo/types": "workspace:^",
		"@symbion/runtype": "^1.2.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"dayjs": "^1.11.20",
		"debounce": "^3.0.0",
		"downshift": "^9.3.2",
		"jotai": "^2.20.0",
		"react-i18next": "^17.0.6",
		"react-icons": "^5.6.0",
		"react-markdown": "^10.1.0",
		"react-popper": "^2.3.0",
		"react-qr-code": "^2.0.21",
		"react-router-dom": "^7.15.0",
		"rimraf": "^6.1.3",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"y-websocket": "^3.0.0",
		"yjs": "^13.6.30"
	},
	"peerDependencies": {
		"react": "^19.1.0",
		"react-dom": "^19.1.0"
	}
}
