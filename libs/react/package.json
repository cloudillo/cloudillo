{
	"name": "@cloudillo/react",
	"version": "0.8.16",
	"description": "React hooks and component library for Cloudillo apps — auth, real-time data, i18n, and OpalUI integration",
	"keywords": [
		"cloudillo",
		"react",
		"hooks",
		"components",
		"ui",
		"i18n",
		"jotai",
		"decentralized",
		"collaboration"
	],
	"homepage": "https://cloudillo.org",
	"repository": {
		"type": "git",
		"url": "https://github.com/cloudillo/cloudillo.git",
		"directory": "libs/react"
	},
	"bugs": {
		"url": "https://github.com/cloudillo/cloudillo/issues"
	},
	"type": "module",
	"main": "lib/index.js",
	"exports": {
		".": "./lib/index.js",
		"./components.css": "./lib/components.css"
	},
	"files": [
		"lib",
		"README.md"
	],
	"scripts": {
		"ts": "tsgo --noEmit",
		"build": "tsgo && cp src/components.css lib/",
		"build-ts": "tsc && cp src/components.css lib/",
		"watch": "tsgo -w",
		"test": "NODE_OPTIONS=\"--experimental-vm-modules\" jest",
		"clean": "rimraf .cache lib*"
	},
	"author": "Szilárd Hajba <szilu@cloudillo.org>",
	"license": "LGPL-3.0-or-later",
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@cloudillo/core": "workspace:^",
		"@cloudillo/crdt": "workspace:^",
		"@cloudillo/fonts": "workspace:^",
		"@cloudillo/rtdb": "workspace:^",
		"@cloudillo/types": "workspace:^",
		"@symbion/runtype": "^1.2.1",
		"@types/jest": "^30.0.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"dayjs": "^1.11.21",
		"debounce": "^3.0.0",
		"downshift": "^9.4.0",
		"jest": "^30.4.2",
		"jest-environment-jsdom": "^30.4.1",
		"jotai": "^2.20.1",
		"react-i18next": "^17.0.9",
		"react-icons": "^5.7.0",
		"react-markdown": "^10.1.0",
		"react-popper": "^2.3.0",
		"react-qr-code": "^2.2.0",
		"react-router-dom": "^7.18.1",
		"rimraf": "^6.1.3",
		"ts-jest": "^29.4.11",
		"tslib": "^2.8.1",
		"typescript": "^7.0.2",
		"y-websocket": "^3.0.0",
		"yjs": "^13.6.31"
	},
	"peerDependencies": {
		"react": "^19.1.0",
		"react-dom": "^19.1.0"
	}
}
