{
	"name": "@cloudillo/rtdb",
	"version": "0.8.17",
	"description": "Real-time, queryable database client for Cloudillo — Firestore-style API with subscriptions, batches, and document locking",
	"keywords": [
		"cloudillo",
		"real-time",
		"database",
		"rtdb",
		"firestore",
		"websocket",
		"subscriptions",
		"decentralized"
	],
	"homepage": "https://cloudillo.org",
	"repository": {
		"type": "git",
		"url": "https://github.com/cloudillo/cloudillo.git",
		"directory": "libs/rtdb"
	},
	"bugs": {
		"url": "https://github.com/cloudillo/cloudillo/issues"
	},
	"type": "module",
	"main": "lib/index.js",
	"exports": {
		".": {
			"import": "./lib/index.js",
			"types": "./lib/index.d.ts"
		}
	},
	"files": [
		"lib",
		"README.md"
	],
	"scripts": {
		"ts": "tsgo --noEmit",
		"build": "tsgo",
		"build-ts": "tsc",
		"watch": "tsgo -w",
		"clean": "rimraf .cache lib*",
		"test": "NODE_OPTIONS=\"--experimental-vm-modules\" jest",
		"test:watch": "NODE_OPTIONS=\"--experimental-vm-modules\" jest --watch",
		"test:coverage": "NODE_OPTIONS=\"--experimental-vm-modules\" jest --coverage"
	},
	"author": "Szilárd Hajba <szilu@cloudillo.org>",
	"license": "LGPL-3.0-or-later",
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@cloudillo/core": "workspace:^",
		"@cloudillo/types": "workspace:^",
		"@jest/globals": "^30.4.1",
		"@symbion/runtype": "^1.2.1",
		"@types/jest": "^30.0.0",
		"@types/node": "^26.1.1",
		"jest": "^30.4.2",
		"rimraf": "^6.1.3",
		"ts-jest": "^29.4.11",
		"tslib": "^2.8.1",
		"typescript": "^7.0.2"
	}
}
