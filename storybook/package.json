{
	"name": "@cloudillo/storybook",
	"version": "0.8.12",
	"description": "Cloudillo Component Storybook",
	"type": "module",
	"main": "src/index.js",
	"scripts": {
		"ts": "tsc --noEmit",
		"ts-watch": "tsc --noEmit --watch",
		"prebuild": "pnpm run ts && node bundle-themes.mjs",
		"build": "node esbuild.config.js",
		"watch": "node esbuild.config.js --watch",
		"serve": "http-server dist -p 8000 -c-1",
		"dev": "concurrently -k -n build,serve -c blue,green \"pnpm watch\" \"pnpm serve\"",
		"clean": "rimraf .cache dist/assets-*"
	},
	"author": "Szilárd Hajba <szilu@cloudillo.org>",
	"license": "LGPL-3.0-or-later",
	"devDependencies": {
		"@cloudillo/core": "workspace:*",
		"@cloudillo/react": "workspace:*",
		"@cloudillo/types": "workspace:*",
		"@symbion/opalui": "^0.14.7",
		"@symbion/runtype": "^1.2.1",
		"@types/debounce": "^1.2.4",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"concurrently": "^9.1.0",
		"debounce": "^3.0.0",
		"http-server": "^14.1.1",
		"downshift": "^9.3.2",
		"esbuild": "^0.27.5",
		"i18next": "^26.0.3",
		"jotai": "^2.19.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-i18next": "^17.0.2",
		"react-icons": "^5.6.0",
		"react-markdown": "^10.1.0",
		"react-popper": "^2.3.0",
		"react-router": "^7.13.2",
		"react-router-dom": "^7.13.2",
		"rimraf": "^6.1.3",
		"tslib": "^2.8.1",
		"typescript": "^6.0.2"
	}
}
